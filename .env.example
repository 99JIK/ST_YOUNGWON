# ============================================
# ST영원 스마트 오피스 환경 설정
# 이 파일을 .env로 복사 후 값을 수정하세요
# cp .env.example .env
# ============================================

# === LLM Provider ===
# openai  : OpenAI API (GPT-4o 등, API 키 필요)
# claude  : Anthropic API (Claude, API 키 필요)
# gemini  : Google Gemini API (API 키 필요)
# ollama  : 로컬/원격 Ollama 서버 (무료, 자체 GPU 필요)
LLM_PROVIDER=ollama

# === API Keys (사용하는 provider만 입력) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# === LLM 모델 설정 ===
# OpenAI (LLM_PROVIDER=openai)
OPENAI_MODEL=gpt-4o-mini

# Anthropic (LLM_PROVIDER=claude)
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Gemini (LLM_PROVIDER=gemini)
GEMINI_MODEL=gemini-2.0-flash

# Ollama (LLM_PROVIDER=ollama)
# 같은 PC: http://localhost:11434
# 외부 PC: http://<PC_IP>:11434 (OLLAMA_HOST=0.0.0.0 설정 필요)
# Docker 내부: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# === LLM 파라미터 ===
# temperature: 0에 가까울수록 일관된 답변, 1에 가까울수록 창의적
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# === Embedding ===
# openai : text-embedding-3-small (유료, 고품질)
# ollama : nomic-embed-text (무료, Ollama 필요)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# === RAG 설정 ===
# chunk_size: 문서 분할 크기 (토큰). 클수록 맥락↑ 정확도↓
# chunk_overlap: 청크 간 겹침. 맥락 유지에 도움
# retrieval_top_k: 검색 결과 개수. 많을수록 포괄적
# similarity_threshold: 유사도 임계값. 낮출수록 더 많은 결과 포함
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.3

# === 업로드 ===
MAX_UPLOAD_SIZE_MB=200

# === Synology NAS ===
# NAS 주소 (예: http://192.168.1.100:5000 또는 https://nas.example.com:5001)
SYNOLOGY_URL=
# NAS 계정 (FileStation 접근 권한 필요)
SYNOLOGY_USERNAME=
SYNOLOGY_PASSWORD=
# HTTPS 사용 시 SSL 인증서 검증 여부 (자체 서명 인증서면 false)
SYNOLOGY_VERIFY_SSL=false

# === 관리자 / 보안 (반드시 변경하세요) ===
ADMIN_PASSWORD=your-secure-password
SECRET_KEY=change-this-secret-key-in-production

# === Docker 포트 (docker-compose 전용) ===
# APP_PORT=8080

# === 로깅 ===
# DEBUG: 상세 디버그 로그 / INFO: 일반 / WARNING: 경고만 / ERROR: 에러만
LOG_LEVEL=INFO
